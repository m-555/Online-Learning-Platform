# Copy to .env and adjust. Used by docker-compose and local development.
# Never commit a real .env — it is gitignored.

# ---- PostgreSQL ----
POSTGRES_USER=aula
POSTGRES_PASSWORD=aula
POSTGRES_DB=aula

# ---- Backend (FastAPI) ----
# Local (host) Postgres:
DATABASE_URL=postgresql+psycopg2://aula:aula@localhost:5432/aula
# Used by the pytest suite (a separate database):
TEST_DATABASE_URL=postgresql+psycopg2://aula:aula@localhost:5432/aula_test
# Secret used to sign JWTs — generate a strong random value for any real deployment.
JWT_SECRET=dev-secret-change-me
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ---- Frontend (Next.js) ----
# Browser-facing API URL (inlined into the client bundle at build time):
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Server-side rendering API URL (defaults to NEXT_PUBLIC_API_URL if unset):
INTERNAL_API_URL=http://localhost:8000/api
